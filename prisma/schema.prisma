generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agence {
  id              Int      @id @default(autoincrement())
  nomComplet      String
  telephone       String
  email           String   @unique
  nomAgence       String
  pays            String
  ville           String
  tailleAgence    String
  logicielGestion Boolean // true = oui, false = non
  commentaire     String? // champ optionnel
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
